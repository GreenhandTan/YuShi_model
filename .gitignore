# 忽略所有文件夹中的数据集和外部依赖
data/
outputs/
wandb/
DataSet/
external/
reports/
scripts/

# 忽略临时和中间产物
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/
.DS_Store
.idea/
.vscode/
*.log

# ---------------------------------------------
# 模型文件处理规则 (仅保留必要的模型文件入库)
# ---------------------------------------------
# 默认忽略所有权重和中间检查点文件
*.pt
*.bin
*.onnx

# 允许根目录下 checkpoints 中的模型文件和词汇表
/checkpoints/*
!/checkpoints/model.onnx
!/checkpoints/vocab.json

# VS Code Copilot
.github/copilot-instructions.md
