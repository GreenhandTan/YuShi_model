# 忽略所有文件夹中的数据集和外部依赖
data/
outputs/
wandb/
DataSet/
external/
reports/
scripts/

# 忽略临时和中间产物
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/
.DS_Store
.idea/
.vscode/
*.log

# ---------------------------------------------
# 模型文件处理规则 (仅保留必要的模型文件入库)
# ---------------------------------------------
# 默认忽略所有权重和中间检查点文件
*.pt
*.bin
*.onnx

# 完全忽略根目录下的本地训练模型输出目录
/checkpoints/

# 显式允许deploy文件夹下的所有用于发布的模型文件
!deploy/checkpoints/
!deploy/checkpoints/*
!deploy/checkpoints/*.onnx
!deploy/checkpoints/*.json

# VS Code Copilot
.github/copilot-instructions.md
